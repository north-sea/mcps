# NAS 环境变量模板
# 复制为 nas.local.env 并填入真实值，不要提交 .local 文件

# --- hermes-db ---
PG_DSN=postgresql://user:password@your-nas-host:5432/hermes
# Optional but recommended for release migrations when PG_DSN uses a non-owner app role.
MIGRATION_PG_DSN=postgresql://migration-owner:password@your-nas-host:5432/hermes
REDIS_URL=redis://your-nas-host:6379/0
EMBEDDING_BASE_URL=http://your-nas-host:3000/v1
EMBEDDING_API_KEY=sk-your-token
EMBEDDING_MODEL=BAAI/bge-m3
# 0 disables the dimensions request parameter; set a positive value only for
# embedding providers/models that explicitly support custom dimensions.
EMBEDDING_DIMENSION=0
TRANSPORT=streamable-http
API_TOKEN=change-me

# --- 镜像仓库 ---
REGISTRY=ghcr.io/northseacoder
